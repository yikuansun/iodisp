{
    "name": "iodisp",
    "productName": "ioDisp",
    "description": "Keyboard Input Display",
    "version": "1.1.0",
    "type": "module",
    "author": {
        "name": "Yikuan Sun",
        "url": "https://yikuansun.github.io",
        "email": "yikuan@example.com"
    },
    "homepage": "https://github.com/yikuansun/iodisp",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "pack": "electron-builder --dir",
        "dist:windows": "electron-builder --windows",
        "dist:mac": "electron-builder --mac",
        "dist:linux": "electron-builder --linux",
        "dist": "electron-builder --mac --linux --windows"
    },
    "devDependencies": {
        "electron": "^42.0.0",
        "electron-builder": "^25.0.0"
    },
    "dependencies": {
        "electron-window-state": "^5.0.3",
        "uiohook-napi": "^1.5.0"
    },
    "build": {
        "appId": "com.electron.iodisp",
        "files": [
            "main.js",
            "preload.cjs",
            "app/**/*"
        ],
        "win": {
            "target": "portable",
            "signAndEditExecutable": false
        },
        "mac": {
            "target": "zip"
        },
        "linux": {
            "target": "deb"
        }
    }
}
