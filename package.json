{
    "name": "iodisp",
    "productName": "ioDisp",
    "description": "Keyboard Input Display",
    "version": "1.0.0",
    "type": "module",
    "author": {
        "name": "Yikuan Sun",
        "url": "https://yikuansun.github.io"
    },
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "pack": "electron-builder --dir",
        "dist": "electron-builder --mac --linux --windows"
    },
    "devDependencies": {
        "electron": "^42.0.0",
        "electron-builder": "^25.0.0"
    },
    "dependencies": {
        "electron-window-state": "^5.0.3",
        "uiohook-napi": "^1.5.0"
    },
    "build": {
        "appId": "com.electron.iodisp",
        "files": [
            "main.js",
            "preload.cjs",
            "app/**/*"
        ],
        "mac": {
            "target": "zip"
        }
    }
}
